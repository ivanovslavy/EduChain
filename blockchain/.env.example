# ---------------------------------------------------------------------------
# EduChain — blockchain/.env.example
#
# Copy this file to `.env` and fill in the keys you actually need.
# `.env` is gitignored.
# ---------------------------------------------------------------------------

# RPC providers (optional — public RPC is used as a fallback for Sepolia)
ALCHEMY_API_KEY=
INFURA_API_KEY=

# Etherscan — required for `hardhat verify` on Sepolia / mainnet
ETHERSCAN_API_KEY=

# Signer keys. USER1 is the deployer in scripts/deploy.js.
# Never commit real private keys.
USER1_PRIVATE_KEY=
USER2_PRIVATE_KEY=
USER3_PRIVATE_KEY=
USER4_PRIVATE_KEY=
USER5_PRIVATE_KEY=

# Optional — only if you also deploy to BSC / Polygon
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=

# Set to any non-empty value to enable hardhat-gas-reporter during tests
REPORT_GAS=
